#!/bin/sh
#
# Description: Show and control display brightness using the brightness script.
#
# See: ~/bin/brightness
#

# Set brightness based on mouse command
case $BLOCK_BUTTON in
	1) brightness set 100 ;;
	2) brightness set 60 ;;
	3) brightness set 30 ;;
	4) brightness inc 5 ;;
	5) brightness dec 5 ;;
esac

brightness=$(brightness get)

# Set icon based on brightness level (7 levels)
case $UI_ICON in
	emoji)
		if [ $brightness -lt 50 ]; then
			icon=ūüĒÖ
		else
			icon=ūüĒÜ
		fi
		;;
	nerd | *)
		if [ $brightness -le 14 ]; then
			icon=ůįÉö
		elif [ $brightness -le 28 ]; then
			icon=ůįÉõ
		elif [ $brightness -le 42 ]; then
			icon=ůįÉú
		elif [ $brightness -le 57 ]; then
			icon=ůįÉĚ
		elif [ $brightness -le 71 ]; then
			icon=ůįÉě
		elif [ $brightness -le 85 ]; then
			icon=ůįÉü
		else
			icon=ůįÉ†
		fi
		;;
esac

echo "$icon  $brightness%"
